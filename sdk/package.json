{
  "name": "@onboarder/sdk",
  "version": "1.1.0",
  "description": "Onboarder embedded agent SDK — supports Vanilla JS, React, Vue 3, Angular",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,

  "main"   : "dist/onboarder.cjs.js",
  "module" : "dist/onboarder.esm.js",
  "types"  : "dist/types/core.d.ts",

  "exports": {
    ".": {
      "import"  : "./dist/onboarder.esm.js",
      "require" : "./dist/onboarder.cjs.js",
      "types"   : "./dist/types/core.d.ts"
    },
    "./react": {
      "import"  : "./dist/react.esm.js",
      "require" : "./dist/react.cjs.js",
      "types"   : "./dist/types/react.d.ts"
    },
    "./vue": {
      "import"  : "./dist/vue.esm.js",
      "require" : "./dist/vue.cjs.js",
      "types"   : "./dist/types/vue.d.ts"
    },
    "./angular": {
      "import"  : "./dist/angular.esm.js",
      "require" : "./dist/angular.cjs.js",
      "types"   : "./dist/types/angular.d.ts"
    },
    "./widget": {
      "import"  : "./dist/widget.esm.js",
      "require" : "./dist/widget.cjs.js",
      "types"   : "./dist/types/widget.d.ts"
    }
  },

  "files": ["dist", "src"],

  "scripts": {
    "build"      : "vite build && vite build --config vite.iife.config.ts",
    "build:esm"  : "vite build",
    "build:iife" : "vite build --config vite.iife.config.ts",
    "dev"        : "vite build --watch"
  },

  "peerDependencies": {
    "react"       : ">=17.0.0",
    "react-dom"   : ">=17.0.0",
    "vue"         : ">=3.0.0",
    "@angular/core": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react"        : { "optional": true },
    "react-dom"    : { "optional": true },
    "vue"          : { "optional": true },
    "@angular/core": { "optional": true }
  },

  "devDependencies": {
    "@types/react": "^18.0.0",
    "react"       : "^18.0.0",
    "react-dom"   : "^18.0.0",
    "typescript"  : "^5.0.0",
    "vite"        : "^5.0.0",
    "vue"         : "^3.0.0"
  }
}
