{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@onboarder/sdk":          ["./sdk/src/index.ts"],
      "@onboarder/sdk/react":    ["./sdk/src/react.tsx"],
      "@onboarder/sdk/vue":      ["./sdk/src/vue.ts"],
      "@onboarder/sdk/angular":  ["./sdk/src/angular.ts"],
      "@onboarder/sdk/widget":   ["./sdk/src/widget.tsx"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
